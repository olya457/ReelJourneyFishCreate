# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'ReelJourneyFishCreate' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Work around fmt 11.0.2 consteval failures with Apple Clang in Xcode 26.4+.
    # Keep fmt on C++17 and patch its generated pod header because a compiler
    # -D flag is overwritten by fmt's own FMT_USE_CONSTEVAL detection block.
    installer.pods_project.targets.each do |pod_target|
      next unless pod_target.name == 'fmt'

      pod_target.build_configurations.each do |build_configuration|
        build_configuration.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
      end
    end

    fmt_base_header = File.join(
      installer.sandbox.pod_dir('fmt'),
      'include',
      'fmt',
      'base.h'
    )

    if File.exist?(fmt_base_header)
      header_contents = File.read(fmt_base_header)
      patched_contents = header_contents.gsub(
        /^(#\s*define FMT_USE_CONSTEVAL) 1$/,
        '\\1 0'
      )

      if patched_contents != header_contents
        File.chmod(0644, fmt_base_header)
        File.write(fmt_base_header, patched_contents)
        Pod::UI.puts 'Patched fmt/base.h: FMT_USE_CONSTEVAL=0'.green
      end
    end
  end
end
